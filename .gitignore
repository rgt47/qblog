/.gitignore
/.Rproj.user

# Post directories are individual git repos — ignore their contents
# but track the NN-name/ lead-in directories themselves
posts/*/archive/
posts/*/*/.git/
posts/*/*/renv/library/
posts/*/*/renv/sandbox/
posts/*/*/renv/staging/
posts/*/*/_site/
posts/*/*/_freeze/

about/*
blog/*
software/*
talks/*
teaching/*
misc/*
!misc/index.qmd
publications/*
README.md
_freeze
notes.txt
profile.jpg
qblog.Rproj
styles.css

/.quarto/

**/.claude/settings.local.json

**/*.quarto_ipynb
