# dotfiles/.gitignore
# Place this file at the root of your ~/dotfiles repository.
# Write it BEFORE running git init; one committed secret
# requires a full git filter-repo rewrite and credential rotation.

# -----------------------------------------------------------------------
# SENSITIVE: never commit these
# -----------------------------------------------------------------------
secrets/*
!secrets/README.md

# Environment secrets
**/.env
**/.env.local
**/.env.*.local
**/credentials
**/credentials.json

# Cryptographic material
**/*.pem
**/*.key
**/*.p12
**/*.pfx
**/id_rsa
**/id_rsa.pub
**/id_ed25519
**/id_ed25519.pub
**/id_ecdsa
**/id_ecdsa.pub

# Cloud provider credentials
**/.aws/credentials
**/.aws/config

# OAuth and registry tokens
**/.npmrc
**/.netrc
**/.docker/config.json

# GPG private keys (export; never commit)
**/*.gpg
**/*.asc

# -----------------------------------------------------------------------
# PER-MACHINE STATE
# -----------------------------------------------------------------------
*.backup.*
*.backup
.DS_Store
.zsh_history
.zsh_sessions/
.viminfo
.zcompdump
.zcompdump-*
.bash_history

# -----------------------------------------------------------------------
# EDITOR PLUGIN DIRECTORIES (regenerated at install time)
# -----------------------------------------------------------------------
# vim-plug / Vundle
config/vim/bundle/
config/vim/plugged/

# neovim lazy.nvim / packer / coc
config/nvim/plugged/
config/nvim/coc/
config/nvim/lazy/

# -----------------------------------------------------------------------
# LANGUAGE SERVER AND EDITOR CACHES
# -----------------------------------------------------------------------
config/coc/
config/nvim/.cache/
**/__pycache__/
**/*.pyc

# -----------------------------------------------------------------------
# PACKAGE MANAGER CACHES (per-machine; rebuild from Brewfile)
# -----------------------------------------------------------------------
# Do not track Homebrew or pipx caches; they are machine-specific.
